---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import dateFormat from "../utils/dateFormat";

let posts = await getCollection("posts").catch(() => []);

// Fallback: If Content Collections fails (due to spaces in folder paths), use Astro.glob
if (!posts || posts.length === 0) {
  const rawFiles = await Astro.glob("../content/posts/*.{md,mdx}").catch(() => []);
  posts = rawFiles.map((file) => {
    const id = file.file.split('/').pop()?.replace(/\.(md|mdx)$/, '');
    return {
      id: id,
      slug: file.frontmatter.slug || id,
      data: file.frontmatter,
    };
  });
}

posts = posts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate || a.data.date || 0);
  const dateB = new Date(b.data.pubDate || b.data.date || 0);
  return dateB.valueOf() - dateA.valueOf();
});
---

<BaseLayout pageTitle="Welcome to Beverage Story">
  {posts.length > 0 ? (
    <>
      {posts.map((post) => {
        const urlSlug = post.data?.slug || post.slug || post.id;
        const displayTitle = post.data?.title || urlSlug;
        return (
          <PostCard
            url={`/posts/${urlSlug}/`}
            title={displayTitle}
            date={post.data?.pubDate ? dateFormat(post.data.pubDate) : ""}
            description={post.data?.description || ""}
          />
        );
      })}
    </>
  ) : (
    <div style="font-family: sans-serif; text-align: center; margin-top: 20vh;">
      <h1>Welcome to your new blog!</h1>
      <p>No posts were found. Head over to <code>/admin</code> to create your first post using TinaCMS.</p>
    </div>
  )}
</BaseLayout>
